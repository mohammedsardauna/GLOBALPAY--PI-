# GLOBALPAY PI - Environment Configuration

# ========== SERVER ==========
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/globalpay_pi
MONGODB_DEV=mongodb://localhost:27017/globalpay_pi_dev

# ========== JWT AUTHENTICATION ==========
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_12345

# ========== PI NETWORK CONFIGURATION ==========
PI_ENVIRONMENT=testnet
PI_API_URL=https://api.minepi.com
PI_SANDBOX_API_URL=https://sandbox.minepi.com
PI_APP_ID=your_pi_app_id
PI_APP_KEY=your_pi_app_key
PI_WALLET_ADDRESS=your_pi_wallet_address

# ========== PI SDK URLS ==========
PI_SDK_URL=https://sdk.minepi.com/pi-sdk.js
PI_SDK_INTEGRATION_URL=https://docs.minepi.com/developers/sdk-setup
PI_SANDBOX_SDK_URL=https://sandbox.minepi.com/sdk
PI_PAYMENT_AUTHENTICATOR_URL=https://pi-payment-authenticator.herokuapp.com

# ========== OAUTH PROVIDERS ==========
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ========== CHATGPT AI INTEGRATION ==========
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_ORG_ID=your_organization_id
CHATGPT_MODEL=gpt-4
CHATGPT_MAX_TOKENS=2000
CHATGPT_TEMPERATURE=0.7

# ========== EMAIL CONFIGURATION ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=noreply@globalpaypi.com
SUPPORT_EMAIL=support@globalpaypi.com

# ========== PAYMENT PROCESSING ==========
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== REDIS CACHE ==========
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== FILE UPLOAD ==========
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ========== SECURITY ==========
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_key_12345
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========== WEBHOOK CONFIGURATION ==========
WEBHOOK_SECRET=your_webhook_secret_key
WEBHOOK_CALLBACK_URL=http://localhost:3000/api/webhooks
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# ========== GITHUB DEPLOYMENT ==========
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=mohammedsardauna
GITHUB_REPO=GLOBALPAY--PI-

# ========== VERCEL INTEGRATION ==========
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_vercel_project_id
VERCEL_VALIDATION_KEY=your_vercel_validation_key

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FILE=./logs/app.log
SENTRY_DSN=

# ========== ANALYTICS ==========
ANALYTICS_ENABLED=true
ANALYTICS_TRACK_EVENTS=true

# ========== FEATURE FLAGS ==========
ENABLE_MARKETPLACE=true
ENABLE_ADMIN_PANEL=true
ENABLE_SUPPORT_PORTAL=true
ENABLE_ANALYTICS=true
ENABLE_CHATGPT_AI=true
ENABLE_QR_PAYMENTS=true
ENABLE_MULTILINGUAL=true
ENABLE_MULTI_CURRENCY=true

# ========== COMMISSION RATES ==========
PLATFORM_COMMISSION_PERCENT=2.5
MERCHANT_SETTLEMENT_THRESHOLD=1000
MIN_WITHDRAWAL_AMOUNT=10

# ========== CURRENCY CONFIGURATION ==========
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,GBP,JPY,INR,NGN,KES,ZAR,AUD,CAD
EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4/latest

# ========== NOTIFICATIONS ==========
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ========== APP URLS ==========
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000/api
DOCS_URL=http://localhost:3000/docs

# ========== PRODUCTION URLS ==========
PROD_APP_URL=https://globalpaypi.com
PROD_FRONTEND_URL=https://app.globalpaypi.com
PROD_API_URL=https://api.globalpaypi.com

# ========== DEBUG ==========
DEBUG=false
DEBUG_PAYMENTS=false
DEBUG_WEBHOOKS=false
